   "source": [
    "import random\n",
    "\n",
    "position = 0\n",
    "goal = 5\n",
    "\n",
    "while position != goal:\n",
    "    action = random.choice([\"left\", \"right\"])\n",
    "\n",
    "    if action == \"right\":\n",
    "        position += 1\n",
    "    else:\n",
    "        position = max(0, position - 1)\n",
    "\n",
    "    print(action, position)\n",
    "\n",
    "print(\"Goal reached\")"
   ]
  }
